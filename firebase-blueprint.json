{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A tea drink item in the menu.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the drink." },
        "category": { "type": "string", "description": "The category of the drink (e.g., 找好茶, 找奶茶)." },
        "prices": {
          "type": "object",
          "properties": {
            "M": { "type": "number" },
            "L": { "type": "number" }
          },
          "required": ["M", "L"]
        },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category", "prices"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "size": { "type": "string", "enum": ["M", "L"] },
              "sugar": { "type": "string" },
              "ice": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["productId", "name", "size", "sugar", "ice", "price", "quantity"]
          }
        },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "totalPrice", "status", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of tea products."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders."
    }
  }
}
