rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check simplified (since user requested no Google Login)
    // In a real production app, you would use a secret key or fixed path.
    function isAdmin() {
      return true; // Simplified for demo/requested no-auth state
    }

    // 1. Mandatory Size Enforcements & Validation Helpers
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category is string && data.category.size() <= 50 &&
             data.prices is map && 
             data.prices.M is number && data.prices.M >= 0 &&
             data.prices.L is number && data.prices.L >= 0 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000));
    }

    function isValidOrder(data) {
      return data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.status in ['pending', 'preparing', 'completed', 'cancelled'] &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // 2. Collection Rules
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming());
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Admins can see all orders. Customers can only see their own if we tied it to UID, 
      // but for simplicity in a public order system, let's say admins see all, 
      // and others can only 'get' if they know the ID (no list).
      allow list: if isAdmin();
      allow get: if true; 
      
      allow create: if isValidOrder(incoming()) && 
                       incoming().status == 'pending' &&
                       incoming().createdAt == request.time &&
                       incoming().updatedAt == request.time;
      
      allow update: if (
        (isAdmin() && isValidOrder(incoming()) && incoming().updatedAt == request.time) ||
        // Customer can only cancel their own order if it's still pending
        (isValidOrder(incoming()) && 
         incoming().status == 'cancelled' && 
         existing().status == 'pending' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
    }
    
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
